{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",       // Node-friendly
    "outDir": "dist",           // output compiled JS here
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "NodeNext"
  },
  "include": ["src/**/*"]
}
